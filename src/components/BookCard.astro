---
export interface Props {
    title: string;
    author: string;
    price: string;
    imageUrl?: string;
    description: string;
}

const { title, author, price, imageUrl = "https://via.placeholder.com/300x400?text=Book+Cover", description } = Astro.props;
---

<div class="book-card">
    <img class="book-cover" src={imageUrl} alt={`Cover of ${title}`} />
    <div class="book-content">
        <h5 class="book-title">{title}</h5>
        <h6 class="book-author">by {author}</h6>
        <p class="book-description">{description}</p>
        <div class="book-footer">
            <span class="book-price">{price}</span>
            <button class="buy-button">Buy</button>
        </div>
    </div>
</div>

<style>
    .book-card {
        width: 100%;
        max-width: 350px;
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    .book-cover {
        width: 100%;
        height: 250px;
        object-fit: cover;
    }
    .book-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }
    .book-title {
        margin: 0 0 0.5rem 0;
        font-size: var(--fs-600, 1.5rem);
        font-weight: var(--fw-bold, 700);
        color: #111827;
    }
    .book-author {
        margin: 0 0 1rem 0;
        font-size: var(--fs-400, 0.875rem);
        font-weight: var(--fw-semi-bold, 500);
        color: #4b5563;
    }
    .book-description {
        margin: 0 0 1.5rem 0;
        color: #374151;
        flex-grow: 1;
        line-height: 1.5;
    }
    .book-footer {
        margin-top: auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .book-price {
        font-size: 1.25rem;
        font-weight: var(--fw-bold, 700);
        color: #111827;
    }
    .buy-button {
        padding: 0.5rem 1.25rem;
        font-size: var(--fs-500, 1rem);
        font-weight: var(--fw-semi-bold, 500);
        color: #ffffff;
        background-color: var(--primary-orange);
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }
    .buy-button:hover {
        background-color: #b54a11;
    }
</style>