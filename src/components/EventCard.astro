---
interface Props {
    event: {
        id: string;
        title: string;
        date?: string;
        frequency?: string;
        location: string;
        description: string;
    };
    isPeriodic?: boolean;
    leadUrl?: string;
}

const { event, isPeriodic = false, leadUrl } = Astro.props;
---
<div class="event-card" style="height: 100%; box-sizing: border-box;">
    <h3>{event.title}</h3>

    {event.date && (
        <p class="event-detail event-date">
            <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-date"></use></svg>
            <span><strong>Date:</strong> {event.date}</span>
        </p>
    )}

    {event.frequency && (
        <p class="event-detail event-frequency">
            <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-frequency"></use></svg>
            <span><strong>Frequency:</strong> {event.frequency}</span>
        </p>
    )}

    <p class="event-detail event-location">
        <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-location"></use></svg>
        <span><strong>Location:</strong> {event.location}</span>
    </p>

    <p class="event-description">{event.description}</p>

    {isPeriodic && leadUrl && (
        <a href={leadUrl} class="help-button">Take the Lead</a>
    )}
</div>
