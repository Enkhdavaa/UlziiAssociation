---
import { useTranslations } from '../i18n/utils';
import { formatDate, formatTime } from '../lib/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  event: {
    id: string;
    title: string;
    date?: string;
    location: string;
    description: string;
    time?: string;
    endTime?: string;
    acceptsVolunteers?: boolean;
  };
  hasLead?: boolean;
  lang?: Locale;
}

const { event, hasLead = false, lang = 'mn' } = Astro.props;
const t = useTranslations(lang);
---
<div class="event-card">
    <h3>{event.title}</h3>

    {event.date && (
        <p class="event-detail">
            <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-date"></use></svg>
            <span><strong>Date:</strong> {formatDate(event.date)}</span>
        </p>
    )}

    {event.time && (
        <p class="event-detail">
            <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-time"></use></svg>
            <span><strong>Time:</strong> {formatTime(event.time)}{event.endTime ? ` – ${formatTime(event.endTime)}` : ''}</span>
        </p>
    )}

    <p class="event-detail">
        <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-location"></use></svg>
        <span><strong>Location:</strong> {event.location}</span>
    </p>

    <p class="event-description">{event.description}</p>

    {event.acceptsVolunteers && (
        hasLead ? (
            <p class="lead-taken-note">{t('eventCard.leadTaken')}</p>
        ) : (
            <a href={`/${lang}/event/monthly-book-reading/lead?id=${encodeURIComponent(event.id)}`} class="help-button">
                {t('eventCard.volunteer')}
            </a>
        )
    )}
</div>
