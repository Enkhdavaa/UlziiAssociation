---
import './header.css';

const links = [
  { href: '/', text: 'Home' },
  { href: '/news', text: 'News' },
  { href: '/event', text: 'Event' },
  { href: '/donate', text: 'Donate' },
  { href: '/contact', text: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="primary-header">
  <div class="header-container">
    <a href="/" class="logo-link">
      <img class="logo" src="/ulzii.png" alt="Ulzii Association Logo" />
    </a>
    <button
      class="mobile-nav-toggle"
      aria-controls="primary-navigation"
      aria-expanded="false"
    >
      <span class="sr-only">Menu</span>
    </button>
    <nav class="primary-nav-wrapper">
      <ul id="primary-navigation" class="primary-navigation" data-visible="false">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class:list={{ active: link.href === currentPath || (link.href !== '/' && currentPath.startsWith(link.href)) }}
            >
              {link.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const primaryNav = document.querySelector('.primary-navigation');
  const navToggle = document.querySelector('.mobile-nav-toggle');

  if (navToggle && primaryNav) {
    navToggle.addEventListener('click', () => {
      const isVisible = primaryNav.getAttribute('data-visible') === 'true';
      primaryNav.setAttribute('data-visible', String(!isVisible));
      navToggle.setAttribute('aria-expanded', String(!isVisible));
    });
  }
</script>
