---
import './header.css';

const links = [
  { href: '/', text: 'Home' },
  { href: '/event', text: 'Events' },
  { href: '/books', text: 'Library' },
  { href: '/support', text: 'Support' },
  { href: '/contact', text: 'Contact' },
];

const currentPath = Astro.url.pathname;
const userCookie = Astro.cookies.get('user');
const user = userCookie ? (userCookie.json() as { name: string; picture?: string }) : null;
---

<header class="primary-header">
  <div class="header-container">
    <a href="/" class="logo-link">
      <img class="logo" src="/ulzii.png" alt="Ulzii Association Logo" />
    </a>
    <button
      class="mobile-nav-toggle"
      aria-controls="primary-navigation"
      aria-expanded="false"
    >
      <span class="sr-only">Menu</span>
      <svg aria-hidden="true" class="icon-burger-menu" width="32" height="32"><use href="/svgs.svg#burger-menu"></use></svg>
      <svg aria-hidden="true" class="icon-close-menu" width="32" height="32"><use href="/svgs.svg#close-menu"></use></svg>
    </button>
    <nav class="primary-nav-wrapper">
      <ul id="primary-navigation" class="primary-navigation" data-visible="false">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class:list={{ active: link.href === currentPath || (link.href !== '/' && currentPath.startsWith(link.href)) }}
            >
              {link.text}
            </a>
          </li>
        ))}
        <li class="nav-auth">
          {user ? (
            <div class="nav-user">
              <button class="nav-avatar-btn" aria-label="Account menu">
                {user.picture
                  ? <img src={user.picture} alt={user.name} class="nav-avatar" />
                  : <span class="nav-avatar-fallback">{user.name[0]}</span>
                }
              </button>
              <div class="nav-dropdown">
                <div class="nav-dropdown-inner">
                  <span class="nav-dropdown-name">{user.name}</span>
                  <a href="/api/auth/logout" class="nav-logout">Sign out</a>
                </div>
              </div>
            </div>
          ) : (
            <a href={`/login?redirect=${encodeURIComponent(currentPath)}`} class="nav-login">Sign in</a>
          )}
        </li>
      </ul>
    </nav>
  </div>
  <div class="nav-overlay" aria-hidden="true"></div>
</header>

<script>
  const primaryNav = document.querySelector('.primary-navigation');
  const navToggle = document.querySelector('.mobile-nav-toggle');
  const navOverlay = document.querySelector('.nav-overlay');

  function openMenu() {
    primaryNav?.setAttribute('data-visible', 'true');
    navToggle?.setAttribute('aria-expanded', 'true');
    navOverlay?.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    primaryNav?.setAttribute('data-visible', 'false');
    navToggle?.setAttribute('aria-expanded', 'false');
    navOverlay?.classList.remove('active');
    document.body.style.overflow = '';
  }

  if (navToggle && primaryNav) {
    navToggle.addEventListener('click', () => {
      const isVisible = primaryNav.getAttribute('data-visible') === 'true';
      isVisible ? closeMenu() : openMenu();
    });
  }

  navOverlay?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && primaryNav?.getAttribute('data-visible') === 'true') {
      closeMenu();
    }
  });

  const navUser = document.querySelector('.nav-user');
  const avatarBtn = document.querySelector('.nav-avatar-btn');

  if (navUser && avatarBtn) {
    avatarBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      navUser.classList.toggle('open');
    });

    document.addEventListener('click', () => {
      navUser.classList.remove('open');
    });
  }
</script>
