---
import "./footer.css";
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-about">
      <img
        src="/ulzii-without.png"
        alt="Ulzii Association Logo"
        class="footer-logo"
      />
      <p>A non-profit organization dedicated to supporting the Mongolian community.</p>
    </div>
    <div class="footer-links">
      <h3>Quick Links</h3>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/news">News</a></li>
        <li><a href="/event">Events</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
    <div class="footer-social">
      <h3>Follow Us</h3>
      <ul>
        <li>
          <a
            href="https://facebook.com/UlziiAssociation"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img src="/facebook.svg" alt="Facebook" />
            <span>Facebook</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; 2025 Ulzii Association. All Rights Reserved.</p>
  </div>
</footer>
