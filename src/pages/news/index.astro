---
import MainLayout from '../../layouts/MainLayout.astro';
import "./_news.css";
import FacebookPost from '../../components/FacebookPost.astro';

const postUrls = [
    "https://www.facebook.com/UlziiAssociation/posts/pfbid07JW834oFcxPQmFSt5aRL6dMhMhoB3dX52UCr7yCpCaNEHQLBEfMLC9m5z9ukGz1Vl",
    "https://www.facebook.com/UlziiAssociation/posts/pfbid02fx6X1uFMBsvrp71zG3qkML11cTxN88VPrCZGdLAXJk8hEyTMXavjFeXdzZg9YEpFl",
    "https://www.facebook.com/UlziiAssociation/posts/pfbid02XvRYjj4Ld2c9inGCpRficGbFsfYkBFaMwoCFf36eFWYbPDNF3bSmVZNzVemVjcFZl",
];
---
<MainLayout>
    <div class="news-container">
        <div class="news-header">
            <h1 class="news-heading">Latest News</h1>
            <p class="news-subheading">Stay up to date with our latest updates and announcements.</p>
            <a
                href="https://www.facebook.com/UlziiAssociation"
                target="_blank"
                rel="noopener noreferrer"
                class="news-fb-link"
            >
                Follow us on Facebook →
            </a>
        </div>

        <div id="fb-loader" class="loader"></div>

        <div id="fb-posts-grid" class="posts-grid" style="opacity: 0; transition: opacity 0.5s ease;">
            {postUrls.map(postUrl => <FacebookPost postUrl={postUrl} />)}
        </div>
    </div>
</MainLayout>

<script is:inline>
    // Initialize FB SDK manually to catch the render event
    window.fbAsyncInit = function() {
        FB.init({
            xfbml: true,
            version: 'v19.0'
        });

        // Listen for when Facebook finishes rendering the posts
        FB.Event.subscribe('xfbml.render', showPosts);
    };

    function showPosts() {
        const loader = document.getElementById('fb-loader');
        const grid = document.getElementById('fb-posts-grid');
        
        if (loader) loader.style.display = 'none';
        if (grid) grid.style.opacity = '1';
    }

    // Fallback: If FB is blocked by an adblocker, show whatever we have after 5 seconds
    setTimeout(showPosts, 5000);
</script>

<script async defer crossorigin="anonymous" src="https://connect.facebook.net/en_US/sdk.js"></script>