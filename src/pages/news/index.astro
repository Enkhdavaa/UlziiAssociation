---
import MainLayout from '../../layouts/MainLayout.astro';
import "./_news.css";
---
<MainLayout>
    <div class="news-container">
        <div class="news-header">
            <h1 class="news-heading">Latest News</h1>
            <p class="news-subheading">Stay up to date with our latest updates and announcements.</p>
        </div>

        <div class="fb-card">
            <svg class="fb-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#1877f2">
                <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.269h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
            <div class="fb-card-text">
                <h2>Ulzii Association</h2>
                <p>Follow our Facebook page to see the latest news, event updates, and community stories.</p>
            </div>
            <a
                href="https://www.facebook.com/UlziiAssociation"
                target="_blank"
                rel="noopener noreferrer"
                class="fb-card-btn"
            >
                Visit our Facebook page →
            </a>
        </div>
    </div>
</MainLayout>
