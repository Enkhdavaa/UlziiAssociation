---
import MainLayout from '../../layouts/MainLayout.astro';
import "./_news.css";
---
<MainLayout>
    <div class="news-container">
        <div class="news-header">
            <h1 class="news-heading">Latest News</h1>
            <p class="news-subheading">Stay up to date with our latest updates and announcements.</p>
        </div>

        <div class="fb-card">
            <svg class="fb-icon" aria-hidden="true"><use href="/svgs.svg#facebook-login"></use></svg>
            <div class="fb-card-text">
                <h2>Ulzii Association</h2>
                <p>Follow our Facebook page to see the latest news, event updates, and community stories.</p>
            </div>
            <a
                href="https://www.facebook.com/UlziiAssociation"
                target="_blank"
                rel="noopener noreferrer"
                class="fb-card-btn"
            >
                Visit our Facebook page →
            </a>
        </div>
    </div>
</MainLayout>
