---
import MainLayout from '../../layouts/MainLayout.astro';
import './_admin.css';
import { getEvents, getBooks, getAllLeads, getAllBookRequests } from '../../lib/kv';

const userCookie = Astro.cookies.get('user');
const user = userCookie ? (userCookie.json() as { name: string; email: string }) : null;

if (!user) return Astro.redirect('/login');

const adminEmails = (import.meta.env.ADMIN_EMAIL ?? '').split(',').map((e: string) => e.trim()).filter(Boolean);
if (!adminEmails.includes(user.email)) {
  return new Response('403 Forbidden — you are not an admin.', { status: 403 });
}

const [events, books, leads, bookRequests] = await Promise.all([
  getEvents(), getBooks(), getAllLeads(), getAllBookRequests()
]);
---

<MainLayout>
  <div class="adm-wrap">

    <header class="adm-header">
      <span class="adm-title">Admin Panel</span>
      <span class="adm-user">{user.name} — {user.email}</span>
    </header>

    <nav class="adm-tabs" role="tablist">
      <button class="adm-tab adm-tab--active" role="tab" data-tab="events">Events <span class="adm-badge">{events.length}</span></button>
      <button class="adm-tab" role="tab" data-tab="books">Books <span class="adm-badge">{books.length}</span></button>
      <button class="adm-tab" role="tab" data-tab="book-requests">Book Requests <span class="adm-badge">{bookRequests.length}</span></button>
      <button class="adm-tab" role="tab" data-tab="leads">Leads <span class="adm-badge">{leads.length}</span></button>
    </nav>

    <div id="adm-status" class="adm-status" hidden></div>

    <section class="adm-section" data-section="events">
      <div class="adm-section-header">
        <h2>Events</h2>
        <button class="adm-btn adm-btn--primary" id="add-event-btn">+ Add Event</button>
      </div>
      <div class="adm-table-wrap">
        <table class="adm-table">
          <thead><tr><th>ID</th><th>Title</th><th>Date</th><th>Time</th><th>Location</th><th>Description</th><th>Volunteers</th><th>Actions</th></tr></thead>
          <tbody>
            {events.map(ev => (
              <tr data-record={JSON.stringify(ev)}>
                <td class="adm-id">{ev.id}</td>
                <td>{ev.title}</td>
                <td>{ev.date}</td>
                <td>{ev.time}</td>
                <td>{ev.location}</td>
                <td class="adm-desc">{ev.description}</td>
                <td>{ev.acceptsVolunteers ? 'Yes' : '—'}</td>
                <td class="adm-actions">
                  <button class="adm-btn adm-btn--sm adm-btn--edit" data-collection="events">Edit</button>
                  <button class="adm-btn adm-btn--sm adm-btn--delete" data-collection="events" data-id={ev.id}>Delete</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="adm-section" data-section="books" hidden>
      <div class="adm-section-header">
        <h2>Books</h2>
        <button class="adm-btn adm-btn--primary" id="add-book-btn">+ Add Book</button>
      </div>
      <div class="adm-table-wrap">
        <table class="adm-table">
          <thead><tr><th>ID</th><th>Title</th><th>Language</th><th>Status</th><th>Description</th><th>Actions</th></tr></thead>
          <tbody>
            {books.map(bk => (
              <tr data-record={JSON.stringify(bk)}>
                <td class="adm-id">{bk.id}</td>
                <td>{bk.title}</td>
                <td>{bk.language || '—'}</td>
                <td><span class={`adm-status-badge adm-status-${bk.status ?? 'available'}`}>{bk.status ?? 'available'}</span></td>
                <td class="adm-desc">{bk.description || '—'}</td>
                <td class="adm-actions">
                  <button class="adm-btn adm-btn--sm adm-btn--edit" data-collection="books">Edit</button>
                  <button class="adm-btn adm-btn--sm adm-btn--delete" data-collection="books" data-id={bk.id}>Delete</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="adm-section" data-section="book-requests" hidden>
      <div class="adm-section-header"><h2>Book Requests</h2></div>
      <div class="adm-table-wrap">
        <table class="adm-table">
          <thead><tr><th>Book</th><th>Name</th><th>Email</th><th>Message</th><th>Requested</th><th>Actions</th></tr></thead>
          <tbody>
            {bookRequests.map(req => (
              <tr data-record={JSON.stringify(req)}>
                <td>{req.bookTitle}</td>
                <td>{req.name}</td>
                <td>{req.email}</td>
                <td class="adm-desc">{req.message || '—'}</td>
                <td>{new Date(req.createdAt).toLocaleDateString()}</td>
                <td class="adm-actions">
                  <button class="adm-btn adm-btn--sm adm-btn--delete" data-collection="book-requests" data-id={req.id}>Delete</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="adm-section" data-section="leads" hidden>
      <div class="adm-section-header">
        <h2>Leads</h2>
        <button class="adm-btn adm-btn--primary" id="add-lead-btn">+ Add Lead</button>
      </div>
      <div class="adm-table-wrap">
        <table class="adm-table">
          <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Event</th><th>Book</th><th>Date</th><th>Time</th><th>Message</th><th>Registered</th><th>Actions</th></tr></thead>
          <tbody>
            {leads.map(ld => (
              <tr data-record={JSON.stringify(ld)}>
                <td>{ld.name}</td>
                <td>{ld.email}</td>
                <td>{ld.countryCode} {ld.phone}</td>
                <td class="adm-id">{ld.eventId}</td>
                <td>{ld.book}</td>
                <td>{ld.date}</td>
                <td>{ld.time}</td>
                <td class="adm-desc">{ld.message}</td>
                <td>{new Date(ld.createdAt).toLocaleDateString()}</td>
                <td class="adm-actions">
                  <button class="adm-btn adm-btn--sm adm-btn--edit" data-collection="leads">Edit</button>
                  <button class="adm-btn adm-btn--sm adm-btn--delete" data-collection="leads" data-id={ld.id} data-event-id={ld.eventId}>Delete</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

  </div>

  <dialog class="adm-dialog" id="adm-modal">
    <form class="adm-form" id="adm-form" method="dialog">
      <h3 class="adm-form-title" id="adm-form-title"></h3>

      <input type="hidden" name="_collection" />
      <input type="hidden" name="_isEdit" />

      <div class="adm-fields" id="fields-events">
        <input name="id" type="hidden" />
        <label>Title<input name="title" type="text" /></label>
        <label>Date<input name="date" type="text" placeholder="May 15, 2026" /></label>
        <label>Time<input name="time" type="text" placeholder="11:00 AM - 12:00 PM" /></label>
        <label>Location<input name="location" type="text" /></label>
        <label>Description<textarea name="description" rows="3"></textarea></label>
        <label class="adm-checkbox-label">
          <input name="acceptsVolunteers" type="checkbox" />
          Accept volunteers <small>shows "Volunteer to Lead" button on the event card</small>
        </label>
      </div>

      <div class="adm-fields" id="fields-books">
        <input name="id" type="hidden" />
        <label>Title<input name="title" type="text" /></label>
        <label>Language
          <select name="language">
            <option value="Mongolian">Mongolian</option>
            <option value="Dutch">Dutch</option>
            <option value="English">English</option>
            <option value="Other">Other</option>
          </select>
        </label>
        <label>Status
          <select name="status">
            <option value="available">Available</option>
            <option value="reserved">Reserved</option>
            <option value="given">Given</option>
            <option value="using">Using (internal)</option>
          </select>
        </label>
        <label>Description<textarea name="description" rows="2" placeholder="Short description (optional)"></textarea></label>
      </div>

      <div class="adm-fields" id="fields-leads">
        <label data-show="create">Event ID<input name="eventId" type="text" /></label>
        <input name="eventId" type="hidden" data-show="edit" />
        <label>Name<input name="name" type="text" /></label>
        <label>Email<input name="email" type="email" /></label>
        <label>Phone
          <div class="adm-phone-row">
            <input name="countryCode" type="text" placeholder="+31" class="adm-input-narrow" />
            <input name="phone" type="text" placeholder="12 345 6789" />
          </div>
        </label>
        <label>Book<input name="book" type="text" /></label>
        <label>Date<input name="date" type="text" /></label>
        <label>Time<input name="time" type="text" /></label>
        <label>Message<textarea name="message" rows="3"></textarea></label>
        <input name="id" type="hidden" />
        <input name="createdAt" type="hidden" />
      </div>

      <div class="adm-form-actions">
        <button type="button" class="adm-btn adm-btn--ghost" id="modal-cancel-btn">Cancel</button>
        <button type="submit" class="adm-btn adm-btn--primary">Save</button>
      </div>
    </form>
  </dialog>
</MainLayout>

<script define:vars={{ eventsJson: JSON.stringify(events), booksJson: JSON.stringify(books), leadsJson: JSON.stringify(leads) }}>
  const COLS     = ['events', 'books', 'leads'];
  const SINGULAR = { events: 'event', books: 'book', leads: 'lead', 'book-requests': 'book request' };

  COLS.forEach(c => { document.getElementById('fields-' + c).style.display = 'none'; });

  // ── Tabs ──────────────────────────────────────────────────────────────────
  document.querySelector('.adm-tabs').addEventListener('click', e => {
    const tab = e.target.closest('[data-tab]');
    if (!tab) return;
    document.querySelectorAll('.adm-tab').forEach(t => t.classList.toggle('adm-tab--active', t === tab));
    document.querySelectorAll('.adm-section').forEach(s => { s.hidden = s.dataset.section !== tab.dataset.tab; });
  });

  // ── Status banner ─────────────────────────────────────────────────────────
  const statusEl = document.getElementById('adm-status');
  let statusTimer;
  function showStatus(msg, isError = false) {
    clearTimeout(statusTimer);
    statusEl.textContent = msg;
    statusEl.className = `adm-status ${isError ? 'adm-status--error' : 'adm-status--ok'}`;
    statusEl.hidden = false;
    statusTimer = setTimeout(() => { statusEl.hidden = true; }, 4000);
  }

  // ── Modal ─────────────────────────────────────────────────────────────────
  const modal = document.getElementById('adm-modal');
  const form  = document.getElementById('adm-form');

  function openModal(collection, record = null) {
    COLS.forEach(c => {
      document.getElementById('fields-' + c).style.display = c === collection ? 'flex' : 'none';
    });

    form.elements['_collection'].value = collection;
    form.elements['_isEdit'].value     = record ? 'true' : 'false';
    document.getElementById('adm-form-title').textContent = `${record ? 'Edit' : 'Add'} ${SINGULAR[collection]}`;

    const fieldset = document.getElementById('fields-' + collection);

    fieldset.querySelectorAll('[data-show]').forEach(el => {
      el.style.display = (record ? el.dataset.show === 'create' : el.dataset.show === 'edit') ? 'none' : '';
    });

    fieldset.querySelectorAll('input, textarea, select').forEach(el => {
      if (el.type === 'checkbox') el.checked = false;
      else el.value = '';
    });

    if (record) {
      Object.entries(record).forEach(([k, v]) => {
        fieldset.querySelectorAll(`[name="${k}"]`).forEach(el => {
          if (el.type === 'checkbox') el.checked = !!v;
          else el.value = v ?? '';
        });
      });
    }

    modal.showModal();
  }

  document.getElementById('modal-cancel-btn').addEventListener('click', () => modal.close());
  document.getElementById('add-event-btn').addEventListener('click', () => openModal('events'));
  document.getElementById('add-book-btn').addEventListener('click',  () => openModal('books'));
  document.getElementById('add-lead-btn').addEventListener('click',  () => openModal('leads'));

  // ── Edit / Delete (event delegation) ─────────────────────────────────────
  document.addEventListener('click', e => {
    const btn = e.target.closest('button');
    if (!btn) return;

    if (btn.classList.contains('adm-btn--edit')) {
      openModal(btn.dataset.collection, JSON.parse(btn.closest('tr').dataset.record));
    }

    if (btn.classList.contains('adm-btn--delete')) {
      const { collection, id } = btn.dataset;
      if (!confirm(`Delete this ${SINGULAR[collection]}? This cannot be undone.`)) return;
      apiCall({ action: 'delete', collection, id, eventId: btn.dataset.eventId })
        .then(() => { showStatus('Deleted.'); btn.closest('tr').remove(); })
        .catch(err => showStatus(String(err), true));
    }
  });

  // ── Form submit ───────────────────────────────────────────────────────────
  form.addEventListener('submit', async e => {
    e.preventDefault();
    const collection = form.elements['_collection'].value;
    const isEdit     = form.elements['_isEdit'].value === 'true';
    const fieldset   = document.getElementById('fields-' + collection);

    const data = {};
    fieldset.querySelectorAll('input, textarea, select').forEach(el => {
      if (!el.name || el.closest('[style*="display: none"]')) return;
      data[el.name] = el.type === 'checkbox' ? el.checked : el.value.trim();
    });

    if (!isEdit && collection === 'events') {
      const time = (data.time ?? '').split(' - ')[0];
      data.id = [data.title, data.date, time].join(' ')
        .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    }

    try {
      await apiCall({ action: 'upsert', collection, data });
      showStatus(`${isEdit ? 'Updated' : 'Created'} successfully. Refreshing…`);
      modal.close();
      setTimeout(() => location.reload(), 800);
    } catch (err) {
      showStatus(String(err), true);
    }
  });

  // ── API ───────────────────────────────────────────────────────────────────
  async function apiCall(body) {
    const res  = await fetch('/api/admin/kv', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    const json = await res.json();
    if (!res.ok) throw new Error(json.error ?? 'Request failed');
    return json;
  }
</script>

<style>
  .adm-status-badge {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    border-radius: 99px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: capitalize;
  }
  .adm-status-available { background: #dcfce7; color: #16a34a; }
  .adm-status-reserved  { background: #fef9c3; color: #a16207; }
  .adm-status-given     { background: #f3f4f6; color: #6b7280; }
  .adm-status-using     { background: #dbeafe; color: #1d4ed8; }
</style>
