---
import MainLayout from '../../layouts/MainLayout.astro'
import BookCard from '../../components/BookCard.astro'

const books = [
    {
        title: "Example: The Great Gatsby",
        author: "F. Scott Fitzgerald",
        price: "$5.00",
        description: "A classic novel of the Jazz Age.",
        imageUrl: "https://via.placeholder.com/300x400?text=The+Great+Gatsby"
    },
    {
        title: "Example: 1984",
        author: "George Orwell",
        price: "$5.00",
        description: "A dystopian social science fiction novel and cautionary tale.",
        imageUrl: "https://via.placeholder.com/300x400?text=1984"
    },
    {
        title: "Example: To Kill a Mockingbird",
        author: "Harper Lee",
        price: "$5.00",
        description: "A novel about the serious issues of rape and racial inequality.",
        imageUrl: "https://via.placeholder.com/300x400?text=To+Kill+a+Mockingbird"
    }
];
---
<MainLayout>
    <div class="buy-books-container">
        <h1 class="page-title">Buy Books</h1>
        <p class="subtitle">All proceeds go towards supporting our association.</p>
        
        <div class="books-grid">
            {books.map(book => <BookCard {...book} />)}
        </div>
    </div>
</MainLayout>

<style>
    .buy-books-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
    }
    .page-title {
        font-size: var(--fs-700, 2.5rem);
        font-weight: var(--fw-bold, 700);
        text-align: center;
        margin-bottom: 0.5rem;
    }
    .subtitle {
        text-align: center;
        color: #4b5563;
        margin-bottom: 3rem;
    }
    .books-grid {
        display: grid;
        /* This will automatically make the grid responsive without media queries */
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        justify-items: center;
    }
</style>