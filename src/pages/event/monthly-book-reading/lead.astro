---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getEvent, getBooks } from '../../../lib/kv';
import "../_event.css";

const eventId = Astro.url.searchParams.get('id') ?? '';
const [event, books] = await Promise.all([getEvent(eventId), getBooks()]);

if (!event) return Astro.redirect('/event');
---

<MainLayout>
    <div class="events-container">
        <div class="lead-page">
            <div class="event-card lead-summary">
                <h2>{event.title}</h2>

                <p class="event-detail event-date">
                    <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-date"></use></svg>
                    <span><strong>Date:</strong> {event.date}</span>
                </p>

                <p class="event-detail event-time">
                    <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-time"></use></svg>
                    <span><strong>Time:</strong> {event.time}</span>
                </p>

                <p class="event-detail event-location">
                    <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-location"></use></svg>
                    <span><strong>Location:</strong> {event.location}</span>
                </p>
            </div>

            <form class="lead-form event-card" method="POST" action={`/api/events/${eventId}/lead`}>
                <h3>Register to Lead</h3>

                {books.length > 0 && (
                    <div class="form-group">
                        <label for="book">Select a Book *</label>
                        <select id="book" name="book" required>
                            {books.map(b => <option value={b.title}>{b.title}</option>)}
                        </select>
                    </div>
                )}

                <div class="form-group">
                    <label for="name">Full Name *</label>
                    <input type="text" id="name" name="name" required />
                </div>

                <div class="form-group">
                    <label for="email">Email Address *</label>
                    <input type="email" id="email" name="email" required />
                </div>

                <div class="form-group">
                    <label for="phone">Phone Number *</label>
                    <div class="phone-input">
                        <select id="country-code" name="countryCode">
                            <option value="+31">NL +31</option>
                            <option value="+976">MN +976</option>
                            <option value="+1">US +1</option>
                            <option value="+44">GB +44</option>
                            <option value="+49">DE +49</option>
                            <option value="+33">FR +33</option>
                            <option value="+32">BE +32</option>
                            <option value="+46">SE +46</option>
                            <option value="+47">NO +47</option>
                            <option value="+45">DK +45</option>
                            <option value="+358">FI +358</option>
                            <option value="+41">CH +41</option>
                            <option value="+43">AT +43</option>
                            <option value="+48">PL +48</option>
                            <option value="+7">RU +7</option>
                            <option value="+86">CN +86</option>
                            <option value="+81">JP +81</option>
                            <option value="+82">KR +82</option>
                            <option value="+91">IN +91</option>
                            <option value="+61">AU +61</option>
                        </select>
                        <input type="tel" id="phone" name="phone" placeholder="12 345 6789" required />
                    </div>
                </div>

                <div class="form-group">
                    <label for="message">Why do you want to lead? (Optional)</label>
                    <textarea id="message" name="message" rows="4"></textarea>
                </div>

                <div class="form-actions">
                    <a href="/event/monthly-book-reading" class="btn-secondary">Cancel</a>
                    <button type="submit" class="help-button">Submit Registration</button>
                </div>
            </form>
        </div>
    </div>
</MainLayout>

<style>
    .lead-page {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
    }

    .lead-form h3 {
        margin-top: 0;
        margin-bottom: 1.5rem;
        color: var(--primary-blue);
    }

    .form-group {
        margin-bottom: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .form-group label {
        font-weight: 600;
        color: #333;
        font-size: 0.9rem;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        padding: 0.75rem;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-family: inherit;
        font-size: 1rem;
        background: white;
        width: 100%;
        box-sizing: border-box;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--primary-blue);
        box-shadow: 0 0 0 3px rgba(0, 86, 179, 0.15);
    }

    .form-group textarea {
        resize: vertical;
    }

    .phone-input {
        display: flex;
        gap: 0.5rem;
    }

    .phone-input select {
        width: auto;
        flex-shrink: 0;
        padding: 0.75rem 0.5rem;
    }

    .phone-input input[type="tel"] {
        flex: 1;
        width: auto;
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        justify-content: flex-end;
        margin-top: 0.5rem;
    }

    .btn-secondary {
        padding: 0.8rem 1.5rem;
        border: 1.5px solid #ccc;
        border-radius: 8px;
        background: white;
        color: #555;
        font-size: 1rem;
        font-weight: 500;
        text-decoration: none;
        transition: border-color 0.2s ease, color 0.2s ease;
    }

    .btn-secondary:hover {
        border-color: #999;
        color: #333;
    }
</style>
