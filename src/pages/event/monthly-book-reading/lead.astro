---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getEvent, getBooks, getLeads } from '../../../lib/kv';
import "../_event.css";

const eventId = Astro.url.searchParams.get('id') ?? '';
const [event, books, leads] = await Promise.all([getEvent(eventId), getBooks(), getLeads(eventId)]);

if (!event) return Astro.redirect('/event');

const existingLead = leads[0] ?? null;
---

<MainLayout>
    <div class="events-container">
        <div class="lead-page">
            <div class="event-card lead-summary">
                <h2>{event.title}</h2>

                <p class="event-detail event-date">
                    <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-date"></use></svg>
                    <span><strong>Date:</strong> {event.date}</span>
                </p>

                <p class="event-detail event-time">
                    <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-time"></use></svg>
                    <span><strong>Time:</strong> {event.time}</span>
                </p>

                <p class="event-detail event-location">
                    <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-location"></use></svg>
                    <span><strong>Location:</strong> {event.location}</span>
                </p>
            </div>

            {existingLead ? (
                <div class="event-card lead-taken">
                    <h3>Storyteller Reserved</h3>
                    <p>This event already has a storyteller for this session.</p>
                    <p>Track the <a href="/event">events page</a> — new story telling events will occur soon.</p>
                    <a href="/event" class="btn-secondary">Back to Events</a>
                </div>
            ) : (
                <form class="lead-form event-card" method="POST" action={`/api/events/${eventId}/lead`}>
                    <input type="hidden" name="date" value={event.date} />
                    <input type="hidden" name="time" value={event.time} />
                    <h3>Volunteer: Register as Storyteller</h3>

                    <div class="lead-intro">
                        <p>We'd love to have you as our storyteller for this session! Here's what to expect:</p>
                        <ul>
                            <li>You'll lead an hour-long storytelling, play, or workshop with the kids.</li>
                            <li>Bring your own book, or reserve one from Ulzii using the <strong>Select a Book</strong> section below.</li>
                        </ul>
                        <p><em>This registration is for this one session only.</em></p>
                    </div>

                    {books.length > 0 && (
                        <div class="form-group">
                            <label for="book">Select a Book *</label>
                            <select id="book" name="book" required>
                                <option value="номоо авч ирнэ (bring my own)">номоо авч ирнэ (bring my own)</option>
                                {books.map(b => <option value={b.title}>{b.title}</option>)}
                            </select>
                        </div>
                    )}

                    <div class="form-group">
                        <label for="name">Full Name *</label>
                        <input type="text" id="name" name="name" required />
                    </div>

                    <div class="form-group">
                        <label for="email">Email Address *</label>
                        <input type="email" id="email" name="email" required />
                    </div>

                    <div class="form-group">
                        <label for="phone">Phone Number *</label>
                        <div class="phone-input">
                            <select id="country-code" name="countryCode">
                                <option value="+31">NL +31</option>
                                <option value="+976">MN +976</option>
                                <option value="+1">US +1</option>
                                <option value="+44">GB +44</option>
                                <option value="+49">DE +49</option>
                                <option value="+33">FR +33</option>
                                <option value="+32">BE +32</option>
                                <option value="+46">SE +46</option>
                                <option value="+47">NO +47</option>
                                <option value="+45">DK +45</option>
                                <option value="+358">FI +358</option>
                                <option value="+41">CH +41</option>
                                <option value="+43">AT +43</option>
                                <option value="+48">PL +48</option>
                                <option value="+7">RU +7</option>
                                <option value="+86">CN +86</option>
                                <option value="+81">JP +81</option>
                                <option value="+82">KR +82</option>
                                <option value="+91">IN +91</option>
                                <option value="+61">AU +61</option>
                            </select>
                            <input type="tel" id="phone" name="phone" placeholder="12 345 6789" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="message">Why do you want to be the storyteller? (Optional)</label>
                        <textarea id="message" name="message" rows="4"></textarea>
                    </div>

                    <div class="form-group terms-group">
                        <label class="terms-label">
                            <input type="checkbox" name="acceptedTerms" required />
                            <span>I confirm that I will attend this event. If I am unable to attend, I will contact you.</span>
                        </label>
                    </div>

                    <div class="form-actions">
                        <a href="/event" class="btn-secondary">Cancel</a>
                        <button type="submit" class="help-button">Register as Storyteller</button>
                    </div>
                </form>
            )}
        </div>
    </div>
</MainLayout>

<style>
    .lead-page {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        width: 100%;
        max-width: 600px;
        margin: 0 auto;
    }

    .lead-taken {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .lead-taken p {
        margin: 0;
        color: #444;
    }

    .lead-taken a {
        color: inherit;
    }

    .lead-form h3 {
        margin-bottom: 1rem;
    }

    .lead-intro {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: #f0f5ff;
        border-left: 3px solid var(--primary-blue);
        border-radius: 6px;
        color: #444;
        font-size: 0.9rem;
        line-height: 1.6;
    }

    .lead-intro p {
        margin: 0;
    }

    .lead-intro ul {
        padding-left: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        list-style: disc;
    }

    .lead-intro strong {
        font-weight: 700;
        color: #222;
    }

    .lead-intro em {
        font-style: italic;
    }

    /* .form-group styles are in src/styles/forms.css */

    .phone-input {
        display: flex;
        gap: 0.5rem;
    }

    .phone-input select {
        width: auto;
        flex-shrink: 0;
        padding: 0.75rem 0.5rem;
    }

    .phone-input input[type="tel"] {
        flex: 1;
        width: auto;
    }

    .terms-label {
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
        font-weight: 400;
        color: #444;
        font-size: 0.9rem;
        cursor: pointer;
        line-height: 1.5;
    }

    .terms-label input[type="checkbox"] {
        margin-top: 0.2rem;
        flex-shrink: 0;
        width: 1rem;
        height: 1rem;
        accent-color: var(--primary-blue);
        cursor: pointer;
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        justify-content: flex-end;
        margin-top: 0.5rem;
    }

    .btn-secondary {
        padding: 0.8rem 1.5rem;
        border: 1.5px solid #ccc;
        border-radius: var(--radius-md);
        background: white;
        color: #555;
        font-size: 1rem;
        font-weight: 500;
        text-decoration: none;
        transition: border-color 0.2s ease, color 0.2s ease;
    }

    .btn-secondary:hover {
        border-color: #999;
        color: #333;
    }
</style>
