---
import MainLayout from '../../layouts/MainLayout.astro'
import { getEvents } from '../../lib/kv'
import "./_event.css"

const events = await getEvents();
const success = Astro.url.searchParams.get('success') === '1';
---
<MainLayout>
    <div class="events-container">
        <h1 class="events-heading">Monthly Storytelling</h1>

        {success && (
            <p class="success-banner">Thank you! Your registration has been received.</p>
        )}

        <div class="events-list">
            {events.map(ev => (
                <div class="event-card">
                    <h3>{ev.title}</h3>

                    <p class="event-detail event-date">
                        <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-date"></use></svg>
                        <span><strong>Date:</strong> {ev.date}</span>
                    </p>

                    <p class="event-detail event-time">
                        <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-time"></use></svg>
                        <span><strong>Time:</strong> {ev.time}</span>
                    </p>

                    <p class="event-detail event-location">
                        <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-location"></use></svg>
                        <span><strong>Location:</strong> {ev.location}</span>
                    </p>

                    <p class="event-description">{ev.description}</p>

                    <a href={`/event/monthly-book-reading/lead?id=${encodeURIComponent(ev.id)}`} class="help-button">
                        Become the Storyteller
                    </a>
                </div>
            ))}
        </div>
    </div>
</MainLayout>

<style>
    .events-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        width: 100%;
        max-width: 700px;
        margin: 0 auto;
    }

    .success-banner {
        max-width: 700px;
        margin: 0 auto 1.5rem;
        padding: 1rem 1.25rem;
        background: #f0fdf4;
        border: 1px solid #86efac;
        border-radius: 8px;
        color: #16a34a;
        font-weight: 500;
    }
</style>
