---
import MainLayout from '../../layouts/MainLayout.astro'
import { getEvents } from '../../lib/kv'
import "./_event.css"
import EventCard from '../../components/EventCard.astro'

const events = await getEvents();
const success = Astro.url.searchParams.get('success') === '1';
---
<MainLayout>
    <div class="events-container">
        <h1 class="events-heading">Monthly Storytelling</h1>

        {success && (
            <p class="success-banner">Thank you! Your registration has been received.</p>
        )}

        <div class="events-list">
            {events.map(ev => (
                <EventCard event={ev} />
            ))}
        </div>
    </div>
</MainLayout>

<style>
    .events-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        width: 100%;
        max-width: 700px;
        margin: 0 auto;
    }

    .success-banner {
        max-width: 700px;
        margin: 0 auto 1.5rem;
        padding: 1rem 1.25rem;
        background: #f0fdf4;
        border: 1px solid #86efac;
        border-radius: 8px;
        color: #16a34a;
        font-weight: 500;
    }
</style>
