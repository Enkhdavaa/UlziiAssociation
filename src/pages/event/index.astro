---
import MainLayout from '../../layouts/MainLayout.astro'
import "./_event.css"
import LeadModal from '../../components/LeadModal.astro'
import EventCard from '../../components/EventCard.astro'

const oneTimeEvents = [
    {
        id: "The Games Around The World",
        title: "The Games Around The World",
        date: "May 30, 2026",
        location: "Eindhoven Library",
        description: "Join us for a day of fun and games as we celebrate cultures from around the world!",
    }
];

const periodicEvents = [
    {
        id: "Monthly Mongolian Book Reading",
        title: "Monthly Mongolian Book Reading",
        frequency: "TO BE DETERMINED",
        location: "Eindhoven Library",
        description: "Join us for a monthly book reading session featuring Mongolian literature.",
    }
];
---
<MainLayout>
    <div class="events-container">
        <h1 class="events-heading">Upcoming Events</h1>
        
        <section class="events-section">
            <h2>One-Time Events</h2>
            <div class="events-grid">
                {oneTimeEvents.map(event => (
                    <EventCard event={event} />
                ))}
            </div>
        </section>

        <section class="events-section">
            <h2>Periodic Events</h2>
            <div class="events-grid">
                {periodicEvents.map(event => (
                    <EventCard event={event} isPeriodic />
                ))}
            </div>
        </section>
        
        <LeadModal />

    </div>
</MainLayout>

<script>
    // Astro defaults script tags to type="module", so they are automatically deferred. No need for DOMContentLoaded.
    const triggerBtns = document.querySelectorAll<HTMLElement>('[data-action="trigger-lead-modal"]');
    
    triggerBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const { eventId, eventTitle } = btn.dataset;
            window.dispatchEvent(new CustomEvent('open-lead-modal', {
                detail: { eventId, eventTitle }
            }));
        });
    });
</script>