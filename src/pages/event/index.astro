---
import MainLayout from '../../layouts/MainLayout.astro'
import "./_event.css"
import EventCard from '../../components/EventCard.astro'
import { getEvents, getLeads } from '../../lib/kv'

const allEvents = await getEvents();
const today = new Date();
today.setHours(0, 0, 0, 0);
const events = allEvents.filter(e => new Date(e.date + 'T00:00:00') >= today);
const success = Astro.url.searchParams.get('success') === '1';

const leadStatusMap: Record<string, boolean> = {};
await Promise.all(
    events
        .filter(e => e.acceptsVolunteers)
        .map(async e => {
            const leads = await getLeads(e.id);
            leadStatusMap[e.id] = leads.length > 0;
        })
);
---
<MainLayout>
    <div class="events-container">
        <h1 class="events-heading">Upcoming Events</h1>

        {success && (
            <p class="success-banner">Thank you! Your registration has been received.</p>
        )}

        {events.length === 0 ? (
            <div class="events-empty">
                <p>No upcoming events at the moment.</p>
                <p>Follow us on <a href="https://www.facebook.com/UlziiAssociation" target="_blank" rel="noopener noreferrer">Facebook</a> to stay updated, or <a href="/contact">get in touch</a> if you'd like to organize one.</p>
            </div>
        ) : (
            <div class="events-list">
                {events.map(event => (
                    <EventCard event={event} hasLead={leadStatusMap[event.id] ?? false} />
                ))}
            </div>
        )}
    </div>
</MainLayout>
