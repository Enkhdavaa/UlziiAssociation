---
import MainLayout from '../../layouts/MainLayout.astro'
import "./_event.css"
import EventCard from '../../components/EventCard.astro'
import { getEvents } from '../../lib/kv'

const events = await getEvents();
---
<MainLayout>
    <div class="events-container">
        <h1 class="events-heading">Upcoming Events</h1>

        {events.length === 0 ? (
            <div class="events-empty">
                <p>No upcoming events at the moment.</p>
                <p>Follow us on <a href="https://www.facebook.com/UlziiAssociation" target="_blank" rel="noopener noreferrer">Facebook</a> to stay updated, or <a href="/contact">get in touch</a> if you'd like to organize one.</p>
            </div>
        ) : (
            <div class="events-grid">
                {events.map(event => (
                    <EventCard event={event} />
                ))}
            </div>
        )}
    </div>
</MainLayout>
