---
import MainLayout from '../../../../layouts/MainLayout.astro';
import { getEvent, getBooks, getLeads } from '../../../../lib/kv';
import '../../../event/_event.css';
import { useTranslations, isValidLocale, DEFAULT_LOCALE } from '../../../../i18n/utils';
import type { Locale } from '../../../../i18n/utils';

const { lang } = Astro.params;
if (!isValidLocale(lang)) return Astro.redirect(`/${DEFAULT_LOCALE}/event`);
const t = useTranslations(lang as Locale);

const eventId = Astro.url.searchParams.get('id') ?? '';
const [event, books, leads] = await Promise.all([getEvent(eventId), getBooks(), getLeads(eventId)]);

if (!event) return Astro.redirect(`/${lang}/event`);

const existingLead = leads[0] ?? null;
---

<MainLayout lang={lang as Locale}>
    <div class="events-container">
        <div class="lead-page">
            <a href={`/${lang}/event`} class="lead-back">
                <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
                {t('lead.back')}
            </a>
            <div class="event-card">
                <h2>{event.title}</h2>

                <p class="event-detail event-date">
                    <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-date"></use></svg>
                    <span><strong>Date:</strong> {event.date}</span>
                </p>

                <p class="event-detail event-time">
                    <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-time"></use></svg>
                    <span><strong>Time:</strong> {event.time}</span>
                </p>

                <p class="event-detail event-location">
                    <svg aria-hidden="true" width="16" height="16" class="event-detail-icon"><use href="/svgs.svg#event-location"></use></svg>
                    <span><strong>Location:</strong> {event.location}</span>
                </p>
            </div>

            {existingLead ? (
                <div class="event-card lead-taken">
                    <h3>{t('lead.takenTitle')}</h3>
                    <p>{t('lead.takenBody')}</p>
                    <p>{t('lead.takenTrack')} <a href={`/${lang}/event`}>{t('lead.takenEventsLink')}</a> {t('lead.takenTrackRest')}</p>
                    <a href={`/${lang}/event`} class="btn-secondary">{t('lead.takenBack')}</a>
                </div>
            ) : (
                <form class="lead-form event-card" method="POST" action={`/api/events/${eventId}/lead`}>
                    <input type="hidden" name="date" value={event.date} />
                    <input type="hidden" name="time" value={event.time} />
                    <input type="hidden" name="lang" value={lang} />
                    <h3>{t('lead.formTitle')}</h3>

                    <div class="lead-intro">
                        <p>{t('lead.introText')}</p>
                        <ul>
                            <li>{t('lead.introBullet1')}</li>
                            <li>{t('lead.introBullet2a')} <strong>{t('lead.introBullet2b')}</strong> {t('lead.introBullet2c')}</li>
                        </ul>
                        <p><em>{t('lead.introNote')}</em></p>
                    </div>

                    {books.length > 0 && (
                        <div class="form-group">
                            <label for="book">{t('lead.selectBook')}</label>
                            <select id="book" name="book" required>
                                <option value={t('lead.ownBook')}>{t('lead.ownBook')}</option>
                                {books.map(b => <option value={b.title}>{b.title}</option>)}
                            </select>
                        </div>
                    )}

                    <div class="form-group">
                        <label for="name">{t('lead.name')}</label>
                        <input type="text" id="name" name="name" required />
                    </div>

                    <div class="form-group">
                        <label for="email">{t('lead.email')}</label>
                        <input type="email" id="email" name="email" required />
                    </div>

                    <div class="form-group">
                        <label for="phone">{t('lead.phone')}</label>
                        <div class="phone-input">
                            <select id="country-code" name="countryCode">
                                <option value="+31">NL +31</option>
                                <option value="+976">MN +976</option>
                                <option value="+1">US +1</option>
                                <option value="+44">GB +44</option>
                                <option value="+49">DE +49</option>
                                <option value="+33">FR +33</option>
                                <option value="+32">BE +32</option>
                                <option value="+46">SE +46</option>
                                <option value="+47">NO +47</option>
                                <option value="+45">DK +45</option>
                                <option value="+358">FI +358</option>
                                <option value="+41">CH +41</option>
                                <option value="+43">AT +43</option>
                                <option value="+48">PL +48</option>
                                <option value="+7">RU +7</option>
                                <option value="+86">CN +86</option>
                                <option value="+81">JP +81</option>
                                <option value="+82">KR +82</option>
                                <option value="+91">IN +91</option>
                                <option value="+61">AU +61</option>
                            </select>
                            <input type="tel" id="phone" name="phone" placeholder="12 345 6789" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="message">{t('lead.whyMessage')}</label>
                        <textarea id="message" name="message" rows="4"></textarea>
                    </div>

                    <div class="form-group terms-group">
                        <label class="terms-label">
                            <input type="checkbox" name="acceptedTerms" required />
                            <span>{t('lead.terms')}</span>
                        </label>
                    </div>

                    <div class="form-actions">
                        <a href={`/${lang}/event`} class="btn-secondary">{t('lead.cancel')}</a>
                        <button type="submit" class="help-button">{t('lead.submit')}</button>
                    </div>
                </form>
            )}
        </div>
    </div>
</MainLayout>
