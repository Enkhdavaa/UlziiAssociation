---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getBooks } from '../../../lib/kv';
import '../../books/_books.css';
import { useTranslations, isValidLocale, DEFAULT_LOCALE } from '../../../i18n/utils';
import type { Locale } from '../../../i18n/utils';

const { lang } = Astro.params;
if (!isValidLocale(lang)) return Astro.redirect(`/${DEFAULT_LOCALE}/books`);
const t = useTranslations(lang as Locale);

const books = await getBooks();
const visibleBooks = books.filter(b => b.status !== 'given');
const availableCount = visibleBooks.filter(b => b.status === 'available').length;
const totalCount = visibleBooks.length;

const userCookie = Astro.cookies.get('user');
const user = userCookie ? (userCookie.json() as { name: string; email: string }) : null;

const strings = {
  requestPrefix: t('books.modalRequestPrefix'),
  success: t('books.requestSuccess'),
  error: t('books.requestError'),
  networkError: t('books.networkError'),
  showing: t('books.showing'),
  of: t('books.of'),
  books: t('books.books'),
  available: t('books.available'),
  total: t('books.total'),
};
---

<MainLayout lang={lang as Locale}>
    <div class="library-container">
        <div class="library-header">
            <h1>{t('books.heading')}</h1>
            <p>{t('books.sub')}</p>
        </div>

        <div class="filter-bar">
            <span class="book-count" id="book-count" data-available={availableCount} data-total={totalCount}>
                <strong>{availableCount}</strong> {t('books.available')} · {totalCount} {t('books.total')}
            </span>
            <label class="toggle-label" for="toggle-available">
                <input type="checkbox" id="toggle-available" class="toggle-input" />
                <span class="toggle-switch"></span>
                {t('books.availableOnly')}
            </label>
        </div>

        {visibleBooks.length === 0 ? (
            <div class="library-empty">
                <p>{t('books.emptyBefore')} <a href={`/${lang}/support/donate-books`}>{t('books.emptyDonate')}</a> {t('books.emptyAfter')}</p>
            </div>
        ) : (
            <div class="books-grid">
                {visibleBooks.map(book => (
                    <div class="book-card" data-status={book.status}>
                        <div class="book-card-top">
                            <div class="book-meta">
                                <span class={`book-status ${book.status}`}>
                                    {book.status === 'available' ? t('books.statusAvailable') : book.status === 'using' ? t('books.statusInUse') : t('books.statusReserved')}
                                </span>
                                {book.language && <span class="book-lang">{book.language}</span>}
                            </div>
                            <h2 class="book-title">{book.title}</h2>
                            {book.description && <p class="book-desc">{book.description}</p>}
                        </div>
                        {book.status === 'available'
                            ? <button class="request-btn" data-book-id={book.id} data-book-title={book.title}>{t('books.requestBtn')}</button>
                            : book.status === 'using'
                            ? <span class="reserved-note">{t('books.inUseNote')}</span>
                            : <span class="reserved-note">{t('books.reservedNote')}</span>
                        }
                    </div>
                ))}
            </div>
        )}
    </div>

    <dialog id="request-modal" class="request-modal">
        <form id="request-form" class="request-form">
            <h3 id="modal-title">{t('books.modalRequestPrefix')}</h3>
            <input type="hidden" id="req-book-id" name="bookId" />
            <input type="hidden" id="req-book-title" name="bookTitle" />
            <div class="form-group">
                <label for="req-name">{t('books.modalName')}</label>
                <input type="text" id="req-name" name="name" required />
            </div>
            <div class="form-group">
                <label for="req-email">{t('books.modalEmail')}</label>
                <input type="email" id="req-email" name="email" required />
            </div>
            <div class="form-group">
                <label for="req-message">{t('books.modalMessage')}</label>
                <textarea id="req-message" name="message" rows="3" placeholder={t('books.modalPlaceholder')}></textarea>
            </div>
            <p id="req-status"></p>
            <div class="modal-actions">
                <button type="button" id="modal-cancel" class="btn-cancel">{t('books.modalCancel')}</button>
                <button type="submit" class="btn-submit">{t('books.modalSubmit')}</button>
            </div>
        </form>
    </dialog>

    {user && <div id="user-prefill" data-name={user.name} data-email={user.email} hidden />}
</MainLayout>

<script define:vars={{ strings }}>
    const modal = document.getElementById('request-modal');
    const form  = document.getElementById('request-form');
    const title = document.getElementById('modal-title');
    const status = document.getElementById('req-status');

    function prefillUser() {
        const el = document.getElementById('user-prefill');
        if (!el) return;
        form.elements.namedItem('name').value  = el.dataset.name;
        form.elements.namedItem('email').value = el.dataset.email;
    }

    document.querySelectorAll('.request-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.getElementById('req-book-id').value = btn.dataset.bookId;
            document.getElementById('req-book-title').value = btn.dataset.bookTitle;
            title.textContent = `${strings.requestPrefix}: ${btn.dataset.bookTitle}`;
            status.textContent = '';
            status.className = '';
            form.reset();
            prefillUser();
            modal.showModal();
        });
    });

    const toggle = document.getElementById('toggle-available');
    const countEl = document.getElementById('book-count');
    const available = Number(countEl.dataset.available);
    const total = Number(countEl.dataset.total);

    toggle?.addEventListener('change', () => {
        document.querySelectorAll('.book-card').forEach(card => {
            card.style.display = toggle.checked && card.dataset.status !== 'available' ? 'none' : '';
        });
        countEl.innerHTML = toggle.checked
            ? `${strings.showing} <strong>${available}</strong> ${strings.of} ${total} ${strings.books}`
            : `<strong>${available}</strong> ${strings.available} · ${total} ${strings.total}`;
    });

    document.getElementById('modal-cancel').addEventListener('click', () => modal.close());
    modal.addEventListener('click', e => { if (e.target === modal) modal.close(); });

    form.addEventListener('submit', async e => {
        e.preventDefault();
        const submitBtn = form.querySelector('[type="submit"]');
        submitBtn.disabled = true;

        try {
            const res = await fetch('/api/books/request', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(new FormData(form))),
            });
            if (res.ok) {
                status.textContent = strings.success;
                status.className = 'status-success';
                form.reset();
                setTimeout(() => modal.close(), 2000);
            } else {
                status.textContent = strings.error;
                status.className = 'status-error';
            }
        } catch {
            status.textContent = strings.networkError;
            status.className = 'status-error';
        } finally {
            submitBtn.disabled = false;
        }
    });
</script>
