---
import MainLayout from '../../../layouts/MainLayout.astro';
import '../../support/_donate.css';
import { useTranslations, isValidLocale, DEFAULT_LOCALE } from '../../../i18n/utils';
import type { Locale } from '../../../i18n/utils';

const { lang } = Astro.params;
if (!isValidLocale(lang)) return Astro.redirect(`/${DEFAULT_LOCALE}/support/donate-books`);
const t = useTranslations(lang as Locale);
---
<MainLayout lang={lang as Locale}>
    <div class="donate-container">
        <div class="donate-header">
            <h1>{t('donate.heading')}</h1>
            <p>{t('donate.sub')}</p>
        </div>

        <div class="donate-card">
            <div class="donate-steps">
                <div class="step">
                    <span class="step-number">1</span>
                    <div>
                        <strong>{t('donate.step1Title')}</strong>
                        <p>{t('donate.step1Desc')}</p>
                    </div>
                </div>
                <div class="step">
                    <span class="step-number">2</span>
                    <div>
                        <strong>{t('donate.step2Title')}</strong>
                        <p>{t('donate.step2Desc')}</p>
                    </div>
                </div>
                <div class="step">
                    <span class="step-number">3</span>
                    <div>
                        <strong>{t('donate.step3Title')}</strong>
                        <p>{t('donate.step3Desc')}</p>
                    </div>
                </div>
            </div>

            <a href={`/${lang}/contact`} class="contact-btn">{t('donate.cta')}</a>
        </div>
    </div>
</MainLayout>
