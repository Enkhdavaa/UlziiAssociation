---
import MainLayout from '../../../layouts/MainLayout.astro';
import '../../support/_support.css';
import { useTranslations, isValidLocale, DEFAULT_LOCALE } from '../../../i18n/utils';
import type { Locale } from '../../../i18n/utils';

const { lang } = Astro.params;
if (!isValidLocale(lang)) return Astro.redirect(`/${DEFAULT_LOCALE}/support`);
const t = useTranslations(lang as Locale);
---
<MainLayout lang={lang as Locale}>
    <div class="support-container">
        <div class="support-header">
            <h1 class="support-title">{t('support.title')}</h1>
            <p class="support-subtitle">{t('support.subtitle')}</p>
        </div>

        <div class="card-container">
            <a href={`/${lang}/support/donate-books`} class="action-card">
                <div class="card-icon donate-icon">
                    <svg width="28" height="28" aria-hidden="true"><use href="/svgs.svg#book-donate"/></svg>
                </div>
                <div class="card-body">
                    <h2>{t('support.donateBooks')}</h2>
                    <p>{t('support.donateBooksDesc')}</p>
                </div>
                <span class="card-arrow">→</span>
            </a>

            <a href={`/${lang}/books`} class="action-card">
                <div class="card-icon library-icon">
                    <svg width="28" height="28" aria-hidden="true"><use href="/svgs.svg#book-library"/></svg>
                </div>
                <div class="card-body">
                    <h2>{t('support.library')}</h2>
                    <p>{t('support.libraryDesc')}</p>
                </div>
                <span class="card-arrow">→</span>
            </a>
        </div>
    </div>
</MainLayout>
