---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
    <div class="not-found">
        <h1 class="not-found-code">404</h1>
        <p class="not-found-msg">This page doesn't exist or may have been moved.</p>
        <div class="not-found-links">
            <a href="/" class="not-found-home">Go to Home</a>
            <a href="/event">Events</a>
            <a href="/books">Library</a>
            <a href="/contact">Contact</a>
        </div>
    </div>
</MainLayout>

<style>
    .not-found {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.25rem;
        padding: 6rem 1.5rem;
        text-align: center;
    }

    .not-found-code {
        font-size: 6rem;
        font-weight: var(--fw-bold);
        color: var(--primary-blue);
        line-height: 1;
    }

    .not-found-msg {
        font-size: var(--fs-500);
        color: var(--color-muted);
    }

    .not-found-links {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 0.5rem;
        font-size: var(--fs-400);
        font-weight: var(--fw-semi-bold);
    }

    .not-found-links a { text-decoration: none; }

    .not-found-links a:not(.not-found-home) { color: var(--primary-blue); }
    .not-found-links a:not(.not-found-home):hover { text-decoration: underline; }

    .not-found-home {
        padding: 0.6rem 1.25rem;
        background: var(--primary-blue);
        color: #fff;
        border-radius: var(--radius-md);
        transition: opacity 0.2s ease;
    }
    .not-found-home:hover { opacity: 0.85; }
</style>
