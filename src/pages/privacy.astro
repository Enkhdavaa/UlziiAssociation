---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
    <div class="container">
        <div class="section">
            <h1>Privacy Policy</h1>
            <p><em>Last updated: April 21, 2026</em></p>

            <h2>Who we are</h2>
            <p>
                Ulzii Association is a non-profit organization dedicated to fostering cultural exchange between Mongolia and the Netherlands. Our website is <strong>ulzii.nl</strong>.
            </p>

            <h2>What data we collect</h2>
            <p>When you sign in using Google or Facebook, we receive and store:</p>
            <ul>
                <li>Your name</li>
                <li>Your email address</li>
                <li>Your profile picture</li>
            </ul>
            <p>We do not collect any other personal data.</p>

            <h2>How we use your data</h2>
            <p>We use your data solely to identify you as a signed-in member of our platform. We do not sell, share, or use your data for advertising or analytics purposes.</p>

            <h2>Cookies</h2>
            <p>We use a single session cookie to keep you signed in. It expires after 7 days. No third-party tracking cookies are used.</p>

            <h2>Data retention</h2>
            <p>Your session data is stored only for the duration of your session (up to 7 days). We do not persist your personal data beyond that.</p>

            <h2>Your rights</h2>
            <p>You may request deletion of your data at any time by contacting us at <a href="mailto:ulziiassociation@gmail.com">ulziiassociation@gmail.com</a>.</p>

            <h2>Contact</h2>
            <p>
                Ulzii Association<br />
                The Netherlands<br />
                <a href="mailto:ulziiassociation@gmail.com">ulziiassociation@gmail.com</a>
            </p>
        </div>
    </div>
</MainLayout>

<style>
    h2 {
        margin-top: 2rem;
    }
    ul {
        padding-left: 1.5rem;
    }
    a {
        color: inherit;
    }
</style>
