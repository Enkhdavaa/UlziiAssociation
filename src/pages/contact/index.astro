---
import MainLayout from '../../layouts/MainLayout.astro'
import "./_contact.css"
---

<script>
    const form = document.querySelector('.contact-form') as HTMLFormElement | null;
    const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
    const statusMsg = document.getElementById('contact-status');

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = form.querySelector<HTMLInputElement>('input[type="email"]')?.value ?? '';
        const question = form.querySelector<HTMLTextAreaElement>('textarea')?.value ?? '';

        if (submitBtn) submitBtn.disabled = true;
        if (statusMsg) { statusMsg.textContent = ''; statusMsg.className = ''; }

        try {
            const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, question }),
            });

            if (res.ok) {
                form.reset();
                if (statusMsg) {
                    statusMsg.textContent = 'Your message has been sent. We will get back to you soon.';
                    statusMsg.className = 'contact-status-success';
                }
            } else {
                if (statusMsg) {
                    statusMsg.textContent = 'Something went wrong. Please try again.';
                    statusMsg.className = 'contact-status-error';
                }
            }
        } catch {
            if (statusMsg) {
                statusMsg.textContent = 'Network error. Please try again.';
                statusMsg.className = 'contact-status-error';
            }
        } finally {
            if (submitBtn) submitBtn.disabled = false;
        }
    });
</script>

<MainLayout>
    <div class="contact-container">
        <div class="contact-inner">

            <div class="contact-info">
                <h1>Get in Touch</h1>
                <p class="contact-intro">
                    Have a question, idea, or just want to say hello? We'd love to hear from you. Fill in the form or reach us directly.
                </p>

                <ul class="contact-details">
                    <li>
                        <span class="contact-detail-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="4" width="20" height="16" rx="2"/>
                                <polyline points="2,4 12,13 22,4"/>
                            </svg>
                        </span>
                        <a href="mailto:ulziiassociation@gmail.com">ulziiassociation@gmail.com</a>
                    </li>
                    <li>
                        <span class="contact-detail-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                <use href="/svgs.svg#facebook-login"></use>
                            </svg>
                        </span>
                        <a href="https://www.facebook.com/UlziiAssociation" target="_blank" rel="noopener noreferrer">
                            Ulzii Association
                        </a>
                    </li>
                </ul>
            </div>

            <form class="contact-form" method="post" action="/">
                <div class="form-group">
                    <label for="email">Your Email</label>
                    <input
                        type="email"
                        id="email"
                        placeholder="you@example.com"
                        required
                    />
                </div>
                <div class="form-group">
                    <label for="question">Message</label>
                    <textarea
                        id="question"
                        name="question"
                        rows="6"
                        placeholder="Write your message here…"
                        minlength="10"
                        wrap="soft"
                        required
                    ></textarea>
                </div>
                <button type="submit" class="submit-button">Send Message</button>
                <p id="contact-status"></p>
            </form>

        </div>
    </div>
</MainLayout>
